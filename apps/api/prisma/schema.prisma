generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GoalType {
  HEALTHY_LIFESTYLE
  IMPROVE_FITNESS
  BUILD_MUSCLE
  IMPROVE_ENDURANCE
  REDUCE_WEIGHT
}

enum GoalImpactMode {
  NUTRITION_ONLY
  NUTRITION_AND_TRAINING
}

enum PrimaryGoal {
  WEIGHT_LOSS
  WEIGHT_MAINTENANCE
  WEIGHT_GAIN
  HEALTHY_EATING
}

enum DietType {
  NONE
  OMNIVORE
  VEGETARIAN
  VEGAN
  PESCATARIAN
  KETO
  LOW_CARB
  MEDITERRANEAN
  HALAL
  KOSHER
}

enum ActivityLevel {
  LOW
  LIGHT
  MODERATE
  HIGH
  ATHLETE
}

enum SportType {
  RUNNING
  CYCLING
  GYM
  STRENGTH
  HIIT
  YOGA
  SWIMMING
  WALKING
  TEAM_SPORT
  OTHER
}

enum IntensityLevel {
  LOW
  MODERATE
  HIGH
}

enum PlanStatus {
  READY
  FALLBACK
}

enum DailyReadinessLevel {
  RECOVER
  MAINTAIN
  PUSH
}

enum WorkoutSessionStatus {
  IN_PROGRESS
  COMPLETED
}

enum PlanFeedbackRating {
  HELPFUL
  NOT_HELPFUL
}

enum PlanFeedbackTag {
  TOO_MUCH_FOOD
  TOO_LITTLE_FOOD
  TRAINING_TOO_HARD
  TRAINING_TOO_EASY
  FELT_GOOD
  LOW_ENERGY
  RECOVERY_NEEDED
}

enum AiOperationFeature {
  DAILY_PLAN
}

enum AiOperationProvider {
  MOCK
  OPENAI
}

enum AiOperationStatus {
  SUCCESS
  FALLBACK
  ERROR
}

enum SubscriptionPlan {
  FREE
  PLUS
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  GRACE_PERIOD
  CANCELED
  EXPIRED
  PAST_DUE
}

enum SubscriptionProvider {
  APP_STORE
  GOOGLE_PLAY
  DEV
}

enum SubscriptionEnvironment {
  SANDBOX
  PRODUCTION
}

enum PlanQualityMode {
  BASIC
  PERSONALIZED
  ADAPTIVE
}

enum PregnancyStatus {
  NOT_PREGNANT
  PREGNANT
  POSTPARTUM
  BREASTFEEDING
  PREFER_NOT_TO_SAY
  UNKNOWN
}

enum UsagePeriodType {
  DAILY
  MONTHLY
}

enum UsageFeature {
  DAILY_PLAN_GENERATION
  DAILY_PLAN_REFRESH
  AI_DAILY_PLAN_GENERATION
  AI_SAFETY_AGENT_REVIEW
  FUTURE_AI_COACH_MESSAGE
}

enum ProgressiveProfilePromptKey {
  PREFERRED_FOODS
  EXCLUDED_FOODS
  DIET_TYPE
  MEALS_PER_DAY
  TARGET_MUSCLE_GROUPS
  TRAINING_OUTCOME
  EQUIPMENT
  TRAINING_LEVEL
  LIMITATIONS_OR_PAIN_AREAS
  COOKING_TIME
  MEAL_PREP
  MEAL_TIMING
}

enum ProgressiveProfilePromptStatus {
  PENDING
  ANSWERED
  SKIPPED
}

enum DailyCheckInType {
  MEAL
  TRAINING
  EVENING_REFLECTION
}

enum TrainingOutcome {
  STRENGTH
  MUSCLE_GROWTH
  ENDURANCE
  MOBILITY
  GENERAL_FITNESS
}

enum TrainingLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TargetMuscleGroup {
  CHEST
  TRAPS
  LATS
  LOWER_BACK
  ABS
  OBLIQUES
  BICEPS
  TRICEPS
  FOREARMS
  QUADRICEPS
  HAMSTRINGS
  ADDUCTORS
  ABDUCTORS
  CALVES
  BACK
  LEGS
  GLUTES
  CORE
  SHOULDERS
  ARMS
  FULL_BODY
}

enum TrainingEquipment {
  GYM
  HOME
  DUMBBELLS
  BODYWEIGHT
  MACHINES
}

enum TrainingEnvironment {
  HOME
  GYM
  OUTDOOR
}

enum TrainingScheduleDayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TrainingScheduleOverrideMode {
  USE_DEFAULT
  CUSTOM
}

enum HealthProvider {
  APPLE_HEALTH
  HEALTH_CONNECT
}

enum HealthConnectionStatus {
  CONNECTED
  DISCONNECTED
  PERMISSION_DENIED
  ERROR
}

enum PreferredLocale {
  EN_US @map("en-US")
  RU_RU @map("ru-RU")
  FR_FR @map("fr-FR")
  ZH_CN @map("zh-CN")
}

enum MeasurementSystem {
  METRIC
  IMPERIAL
}

enum ExerciseCategory {
  STRENGTH
  MOBILITY
  CARDIO
  RECOVERY
}

enum ExerciseEquipment {
  NONE
  BODYWEIGHT
  DUMBBELLS
  BARBELL
  KETTLEBELL
  RESISTANCE_BANDS
  MACHINES
  BENCH
  PULL_UP_BAR
  CABLE_MACHINE
  CARDIO_MACHINE
}

enum MovementPattern {
  SQUAT
  HINGE
  HORIZONTAL_PUSH
  VERTICAL_PUSH
  HORIZONTAL_PULL
  VERTICAL_PULL
  LUNGE
  CARRY
  ROTATION
  ANTI_ROTATION
  CORE_FLEXION
  CORE_STABILITY
  ISOLATION
  MOBILITY
  CARDIO
  RECOVERY
}

enum ExerciseContraindicationTag {
  WRIST_LOAD
  ELBOW_LOAD
  SHOULDER_LOAD
  KNEE_LOAD
  LOWER_BACK_LOAD
  OVERHEAD_POSITION
  BALANCE_REQUIRED
  HIGH_IMPACT
  PRONE_POSITION
  SUPINE_POSITION
  PREGNANCY_REVIEW
  POSTPARTUM_REVIEW
}

enum ExerciseMediaType {
  PRIMARY
  TECHNIQUE
  ANATOMY
  ALTERNATE
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  firstName          String?
  lastName           String?
  timezone           String   @default("UTC")
  locale             String   @default("en")
  isMinor            Boolean  @default(false)
  safeMode           Boolean  @default(false)
  noTrainingPlanned  Boolean  @default(false)
  privacyConsentedAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  profile       Profile?
  goal          Goal?
  nutritionPref NutritionPreference?
  schedules     TrainingScheduleItem[]
  dailyPlans    DailyPlan[]
  planFeedback  DailyPlanFeedback[]
  workoutSessions WorkoutSession[]
  aiOperationLogs AiOperationLog[]
  subscriptions Subscription[]
  usageLedger   UsageLedger[]
  progressiveProfilePrompts UserProgressiveProfilePrompt[]
  dailyPlanCheckIns DailyPlanCheckIn[]
  trainingPreference TrainingPreference?
  weeklyTrainingSchedule TrainingSchedule?
  healthConnections HealthConnection[]
  healthDailySummaries HealthDailySummary[]
  settings UserSettings?

  @@index([createdAt])
}

model UserSettings {
  id                String            @id @default(cuid())
  userId            String            @unique
  preferredLocale   PreferredLocale   @default(EN_US)
  measurementSystem MeasurementSystem @default(METRIC)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([preferredLocale])
  @@index([measurementSystem])
}

model Profile {
  id              String          @id @default(cuid())
  userId          String          @unique
  gender          String?
  pregnancyStatus PregnancyStatus @default(UNKNOWN)
  dateOfBirth     DateTime
  heightCm        Float
  weightKg        Float
  activityLevel   ActivityLevel
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dateOfBirth])
  @@index([pregnancyStatus])
}

model Goal {
  id                 String          @id @default(cuid())
  userId             String          @unique
  goalType           GoalType
  primaryGoal        PrimaryGoal?
  targetWeightKg     Float?
  targetTimelineDays Int?
  impactMode         GoalImpactMode?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NutritionPreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  dietType    DietType @default(NONE)
  mealsPerDay Int      @default(3)
  noKnownAllergiesConfirmed Boolean @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergies      Allergy[]
  excludedFoods  ExcludedFood[]
  dislikedFoods  DislikedFood[]
  preferredFoods PreferredFood[]
}

model Allergy {
  id                    String @id @default(cuid())
  nutritionPreferenceId String
  name                  String

  nutritionPreference NutritionPreference @relation(fields: [nutritionPreferenceId], references: [id], onDelete: Cascade)

  @@index([nutritionPreferenceId])
}

model ExcludedFood {
  id                    String @id @default(cuid())
  nutritionPreferenceId String
  name                  String

  nutritionPreference NutritionPreference @relation(fields: [nutritionPreferenceId], references: [id], onDelete: Cascade)

  @@index([nutritionPreferenceId])
}

model DislikedFood {
  id                    String @id @default(cuid())
  nutritionPreferenceId String
  name                  String

  nutritionPreference NutritionPreference @relation(fields: [nutritionPreferenceId], references: [id], onDelete: Cascade)

  @@index([nutritionPreferenceId])
}

model PreferredFood {
  id                    String @id @default(cuid())
  nutritionPreferenceId String
  name                  String

  nutritionPreference NutritionPreference @relation(fields: [nutritionPreferenceId], references: [id], onDelete: Cascade)

  @@index([nutritionPreferenceId])
}

model TrainingScheduleItem {
  id              String         @id @default(cuid())
  userId          String
  dayOfWeek       Int
  localTime       String
  sportType       SportType
  durationMinutes Int
  intensity       IntensityLevel
  description     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
}

model TrainingSchedule {
  id           String   @id @default(cuid())
  userId       String   @unique
  isActive     Boolean  @default(false)
  weekStartsOn TrainingScheduleDayOfWeek @default(MONDAY)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  days TrainingScheduleDay[]

  @@index([userId, isActive])
}

model TrainingScheduleDay {
  id                 String                       @id @default(cuid())
  trainingScheduleId String
  dayOfWeek          TrainingScheduleDayOfWeek
  isTrainingDay      Boolean                      @default(false)
  targetMusclesMode  TrainingScheduleOverrideMode @default(USE_DEFAULT)
  targetMuscles      TargetMuscleGroup[]          @default([])
  environmentMode    TrainingScheduleOverrideMode @default(USE_DEFAULT)
  environment        TrainingEnvironment?
  equipmentMode      TrainingScheduleOverrideMode @default(USE_DEFAULT)
  availableEquipment ExerciseEquipment[]          @default([])
  durationMode       TrainingScheduleOverrideMode @default(USE_DEFAULT)
  durationMinutes    Int?
  protocolMode       TrainingScheduleOverrideMode @default(USE_DEFAULT)
  protocolPreference String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  trainingSchedule TrainingSchedule @relation(fields: [trainingScheduleId], references: [id], onDelete: Cascade)

  @@unique([trainingScheduleId, dayOfWeek])
  @@index([dayOfWeek])
}

model DailyPlan {
  id             String              @id @default(cuid())
  userId         String
  planLocalDate  String
  planTimezone   String
  status         PlanStatus
  readinessLevel DailyReadinessLevel
  planJson       Json
  createdByAi    Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback DailyPlanFeedback[]
  checkIns DailyPlanCheckIn[]
  workoutSessions WorkoutSession[]

  @@unique([userId, planLocalDate, planTimezone])
  @@index([userId, createdAt])
}

model WorkoutSession {
  id                     String               @id @default(cuid())
  userId                 String
  dailyPlanId            String
  status                 WorkoutSessionStatus @default(IN_PROGRESS)
  startedAt              DateTime             @default(now())
  completedAt            DateTime?
  plannedExerciseCount   Int                  @default(0)
  completedExerciseCount Int                  @default(0)
  plannedSetCount        Int                  @default(0)
  completedSetCount      Int                  @default(0)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyPlan        DailyPlan                 @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  exerciseProgress WorkoutExerciseProgress[]

  @@unique([userId, dailyPlanId])
  @@index([userId, status, updatedAt])
  @@index([dailyPlanId])
}

model WorkoutExerciseProgress {
  id                    String   @id @default(cuid())
  workoutSessionId      String
  planExerciseKey       String
  planExerciseOrder     Int
  exerciseId            String?
  exerciseSlug          String?
  exerciseNameSnapshot  String
  plannedSets           Int?
  plannedReps           String?
  plannedDurationSeconds Int?
  plannedRestSeconds    Int?
  completedSetIndexes   Int[]    @default([])
  isExerciseCompleted   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)

  @@unique([workoutSessionId, planExerciseKey])
  @@index([workoutSessionId, planExerciseOrder])
}

model DailyPlanFeedback {
  id          String              @id @default(cuid())
  userId      String
  dailyPlanId String
  rating      PlanFeedbackRating?
  tags        PlanFeedbackTag[]
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyPlan DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyPlanId])
  @@index([userId, createdAt])
  @@index([dailyPlanId])
}

model AiOperationLog {
  id                  String              @id @default(cuid())
  userId              String
  feature             AiOperationFeature
  provider            AiOperationProvider
  model               String?
  status              AiOperationStatus
  latencyMs           Int
  retryCount          Int                 @default(0)
  safetyAgentEnabled  Boolean             @default(false)
  safetyAgentProvider String?
  safetyAgentApproved Boolean?
  fallbackReason      String?
  errorReason         String?
  createdAt           DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([provider, createdAt])
  @@index([status, createdAt])
}

model Subscription {
  id                     String                  @id @default(cuid())
  userId                 String
  plan                   SubscriptionPlan
  status                 SubscriptionStatus
  provider               SubscriptionProvider
  environment            SubscriptionEnvironment
  providerCustomerId     String?
  providerSubscriptionId String?
  providerTransactionId  String?
  originalTransactionId  String?
  providerProductId      String?
  startsAt               DateTime
  expiresAt              DateTime?
  canceledAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
  @@index([userId, status])
  @@index([provider, providerSubscriptionId])
  @@index([originalTransactionId])
}

model UsageLedger {
  id          String          @id @default(cuid())
  userId      String
  feature     UsageFeature
  periodType  UsagePeriodType
  periodStart DateTime
  count       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature, periodType, periodStart])
  @@index([userId, periodStart])
  @@index([feature, periodStart])
  @@index([userId, feature, periodType, periodStart])
}

model UserProgressiveProfilePrompt {
  id           String                          @id @default(cuid())
  userId       String
  promptKey    ProgressiveProfilePromptKey
  status       ProgressiveProfilePromptStatus  @default(PENDING)
  answerJson   Json?
  answeredAt   DateTime?
  skippedAt    DateTime?
  skippedUntil DateTime?
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promptKey])
  @@index([userId, status])
  @@index([userId, skippedUntil])
}

model DailyPlanCheckIn {
  id          String           @id @default(cuid())
  userId      String
  dailyPlanId String
  type        DailyCheckInType
  subjectKey  String           @default("default")
  payload     Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyPlan DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyPlanId, type, subjectKey])
  @@index([userId, createdAt])
  @@index([dailyPlanId, type])
  @@index([userId, dailyPlanId])
}

model TrainingPreference {
  id                     String              @id @default(cuid())
  userId                 String              @unique
  targetMuscleGroups     TargetMuscleGroup[] @default([])
  trainingOutcome        TrainingOutcome?
  equipment              TrainingEquipment[] @default([])
  trainingLevel          TrainingLevel?
  limitationsOrPainAreas String[]            @default([])
  preferredTrainingDays  Int[]               @default([])
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HealthConnection {
  id                 String                 @id @default(cuid())
  userId             String
  provider           HealthProvider
  status             HealthConnectionStatus @default(DISCONNECTED)
  consentedAt         DateTime?
  disconnectedAt      DateTime?
  lastSyncAt          DateTime?
  permissionsGranted  Json?
  errorReason         String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, status])
  @@index([provider, status])
}

model HealthDailySummary {
  id                  String         @id @default(cuid())
  userId              String
  localDate            String
  timezone             String
  sourceProvider       HealthProvider
  steps                Int?
  sleepMinutes         Int?
  activeEnergyKcal     Int?
  workoutCount         Int?
  workoutMinutes       Int?
  averageHeartRate     Int?
  restingHeartRate     Int?
  weightKg             Decimal?       @db.Decimal(6, 2)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate, sourceProvider])
  @@index([userId, localDate])
  @@index([sourceProvider, localDate])
}

model Exercise {
  id                     String                         @id @default(cuid())
  slug                   String                         @unique
  category               ExerciseCategory
  movementPattern        MovementPattern
  equipment              ExerciseEquipment[]            @default([])
  targetMuscles          TargetMuscleGroup[]             @default([])
  secondaryMuscles       TargetMuscleGroup[]             @default([])
  trainingLevels         TrainingLevel[]                 @default([])
  contraindicationTags   ExerciseContraindicationTag[]   @default([])
  isActive               Boolean                         @default(true)
  sortOrder              Int                             @default(0)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  translations           ExerciseTranslation[]
  media                  ExerciseMedia[]

  @@index([isActive, sortOrder, slug])
  @@index([category, isActive])
  @@index([movementPattern, isActive])
}

model ExerciseTranslation {
  id             String          @id @default(cuid())
  exerciseId     String
  locale         PreferredLocale
  name           String
  description    String?
  instructions   String[]        @default([])
  coachingCues   String[]        @default([])
  safetyNotes    String[]        @default([])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  exercise       Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, locale])
  @@index([locale, name])
}

model ExerciseMedia {
  id             String                     @id @default(cuid())
  exerciseId     String
  seedKey        String?                    @unique
  type           ExerciseMediaType
  url            String
  thumbnailUrl   String?
  width          Int?
  height         Int?
  sortOrder      Int                        @default(0)
  isPrimary      Boolean                    @default(false)
  isActive       Boolean                    @default(true)
  source         String?
  license        String?
  attribution    String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  exercise       Exercise                   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  translations   ExerciseMediaTranslation[]

  @@index([exerciseId, isActive, sortOrder])
  @@index([exerciseId, isPrimary, isActive])
}

model ExerciseMediaTranslation {
  id                String          @id @default(cuid())
  exerciseMediaId   String
  locale            PreferredLocale
  altText           String
  caption           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  exerciseMedia     ExerciseMedia   @relation(fields: [exerciseMediaId], references: [id], onDelete: Cascade)

  @@unique([exerciseMediaId, locale])
  @@index([locale])
}
