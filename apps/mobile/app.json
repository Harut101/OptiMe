{
  "expo": {
    "name": "OptiMe",
    "slug": "optime",
    "scheme": "optime",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.optime.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "OptiMe reads Apple Health activity, sleep, and workout summaries to personalize wellness plans.",
        "NSHealthUpdateUsageDescription": "OptiMe does not write health data."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
