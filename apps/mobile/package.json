{
  "name": "@optime/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:lan": "set REACT_NATIVE_PACKAGER_HOSTNAME=192.168.10.15&& expo start --lan",
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "body-map:generate": "node scripts/generate-body-map.mjs",
    "body-map:validate": "node scripts/validate-body-map.mjs",
    "ia:validate": "node scripts/validate-information-architecture.mjs",
    "interaction:test": "node scripts/test-screen-interactions.mjs",
    "localization:validate": "node scripts/validate-localization.mjs && node scripts/test-localization-contracts.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/validate-information-architecture.mjs && node scripts/test-screen-interactions.mjs && node scripts/validate-localization.mjs && node scripts/test-localization-contracts.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.0.1",
    "@optime/shared-schemas": "workspace:*",
    "@optime/shared-types": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "react-native-health": "^1.19.0",
    "expo": "^54.0.0",
    "expo-health-connect": "^0.1.1",
    "expo-localization": "~17.0.9",
    "expo-router": "^6.0.0",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "^3.0.8",
    "i18next": "^25.0.0",
    "react": "^19.1.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^16.0.0",
    "lucide-react-native": "^0.475.0",
    "react-native": "^0.81.5",
    "react-native-health-connect": "^3.5.3",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.1.17",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo-build-properties": "~1.0.9",
    "typescript": "^5.7.2"
  }
}
